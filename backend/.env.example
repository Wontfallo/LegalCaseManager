# ─────────────────────────────────────────────────────────
# Legal Case Manager – Backend Environment Variables
# Copy this file to .env and fill in real secrets.
#
# For local development: just copy as-is, then uncomment
# the SQLite DATABASE_URL line and comment out the Postgres one.
# The start.bat script auto-generates a .env if one doesn't exist.
# ─────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=DEBUG

# ── Database ─────────────────────────────────────────────
# Option 1: SQLite (local-first, no setup required)
DATABASE_URL=sqlite+aiosqlite:///./storage/legalcm.db
# Option 2: PostgreSQL (production / multi-user)
# DATABASE_URL=postgresql+asyncpg://legalcm:changeme@localhost:5432/legalcm_db

# ── JWT / Auth ───────────────────────────────────────────
# CHANGE THIS – generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ── Encryption (AES-256 simulation) ─────────────────────
# CHANGE THIS – generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
FILE_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX_KEY_00000000

# ── OpenAI (leave empty for offline mode) ────────────────
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o

# ── Mistral OCR (leave empty for offline mode) ───────────
MISTRAL_API_KEY=
MISTRAL_OCR_ENDPOINT=https://api.mistral.ai/v1/ocr

# ── ChromaDB (falls back to local persistent mode) ───────
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=legal_documents

# ── Redis / Celery (optional, only needed for task queue) ─
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Twilio (leave empty for offline mode) ────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WEBHOOK_SECRET=

# ── Webhook Security ────────────────────────────────────
EMAIL_WEBHOOK_SECRET=

# ── File Storage ─────────────────────────────────────────
UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_SIZE_MB=50
