# ─────────────────────────────────────────────────────────
# Legal Case Manager – Docker Environment (SQLite / Offline)
#
# Copy this file to your project root as .env.docker
# then run: docker compose up --build
#
# IMPORTANT: Replace the JWT_SECRET_KEY and FILE_ENCRYPTION_KEY
# with your own random values before deploying!
#
# Generate a secure key:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# ─────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────
# Use "development" for local Docker; switch to "production" after
# changing JWT_SECRET_KEY and FILE_ENCRYPTION_KEY to real values.
APP_ENV=development
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO

# ── Database (SQLite – no external DB needed) ────────────
DATABASE_URL=sqlite+aiosqlite:///./storage/legalcm.db

# ── JWT / Auth ───────────────────────────────────────────
# CHANGE THIS! Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=REPLACE_ME_docker_jwt_secret_key_change_before_deploy
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ── Encryption ───────────────────────────────────────────
# CHANGE THIS! Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
FILE_ENCRYPTION_KEY=REPLACE_ME_docker_encryption_key_change

# ── AI Keys (leave empty for offline mode) ───────────────
OPENAI_API_KEY=
MISTRAL_API_KEY=

# ── ChromaDB (local persistent mode inside container) ────
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=legal_documents

# ── Twilio (leave empty for offline mode) ────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WEBHOOK_SECRET=

# ── Webhook Security ────────────────────────────────────
EMAIL_WEBHOOK_SECRET=

# ── File Storage ─────────────────────────────────────────
UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_SIZE_MB=50

# ── Docker Compose Port Overrides (optional) ─────────────
BACKEND_PORT=8080
FRONTEND_PORT=3000
